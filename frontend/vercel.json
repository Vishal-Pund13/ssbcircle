{
  "rewrites": [
    {
      "source": "/((?!.*\\.(?:xml|txt|png|svg|ico|json|webp|jpg|jpeg|gif|css|js|woff|woff2|ttf)$).*)",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/og-image.png",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "index, follow" }
      ]
    }
  ]
}
