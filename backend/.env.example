PORT=4000
DATABASE_URL=postgresql://user:password@localhost:5432/ssbcircle
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
JWT_SECRET=change_this_to_a_long_random_secret_string
GOOGLE_CLIENT_ID=your_google_client_id

# Jitsi as a Service (JaaS) — get these from https://jaas.8x8.vc
JAAS_APP_ID=vpaas-magic-cookie-xxxxxxxxxxxxxxxxxxxxxxxx
JAAS_KEY_ID=your_key_id_from_jaas_dashboard
# Run: cat private.pem | base64 -w 0   (Linux/Mac) or certutil -encode private.pem tmp && findstr /v "CERTIFICATE" tmp > key_b64.txt (Windows)
JAAS_PRIVATE_KEY_BASE64=base64_encoded_rsa_private_key
